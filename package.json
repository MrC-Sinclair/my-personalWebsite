    "nuxt": "^3.17.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^3.19.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "better-sqlite3": "^12.9.0",
    "cspell": "^8.19.4",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.8"
